# --- Ambientes Virtuais e Dependências ---
.venv/
venv/
ENV/
env/
.env
__pycache__/
*.py[cod]
*$py.class

# --- IDEs (Configurações do PyCharm e VS Code) ---
.idea/
.vscode/

# --- Bancos de Dados Pesados (Essencial para o seu projeto) ---
*.db
*.sqlite
*.sqbpro

# --- Pastas de Dados Locais (Evita subir gigabytes de logs/tabelas) ---
data/raw/
data/processed/
downloads/

# --- Logs e Arquivos Temporários ---
*.log
.DS_Store

# --- Camada de Dashboards ---
