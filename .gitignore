dashboards/*

# PERMISSÕES ESPECÍFICAS:
# Queremos que o GitHub veja APENAS os resultados agregados e leves que geram os gráficos
!dashboards/tam_por_municipio.csv
!dashboards/setores_ranking.csv

# Ignorar o executável do Metabase
export_metabase/
metabase.db.*
*.db.mv.db
*.db.trace.db
plugins/
*.jar
